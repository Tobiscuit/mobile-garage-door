{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/visualize/layout,_N_T_/visualize/page,_N_T_/visualize"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/visualize/__PAGE__",
    "/visualize",
    "/_index",
    "/_head"
  ]
}